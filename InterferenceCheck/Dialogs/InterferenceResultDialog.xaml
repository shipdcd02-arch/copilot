<Window x:Class="InterferenceCheck.Dialogs.InterferenceResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="간섭 검사 결과" Height="720" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#252526" Foreground="#DCDCDC"
        FontFamily="Segoe UI" FontSize="12"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#3C3C3C"/>
            <Setter Property="Foreground"  Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="10,4"/>
            <Setter Property="Margin"      Value="3,0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"   Value="#AAAAAA"/>
            <Setter Property="BorderBrush"  Value="#444"/>
            <Setter Property="Padding"      Value="6"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#DCDCDC"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264F78"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="Auto"/>  <!-- 통계 -->
            <RowDefinition Height="*"/>     <!-- 메인 패널 -->
            <RowDefinition Height="Auto"/>  <!-- 진행 상태 -->
            <RowDefinition Height="Auto"/>  <!-- 하단 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ───────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Background="#1E1E1E" Margin="0,0,0,0">
            <TextBlock Text="간섭 검사 결과" FontSize="14" FontWeight="Bold"
                       Foreground="#4FC3F7" Margin="12,8"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="4,4"/>
            <Button x:Name="BtnZoom"         Content="▶ 선택 항목 줌"
                    Click="BtnZoom_Click"        IsEnabled="False" Margin="4,4"/>
            <Button x:Name="BtnHighlight"    Content="🔴 간섭 영역 표시"
                    Click="BtnHighlight_Click"   IsEnabled="False" Margin="4,4"/>
            <Button x:Name="BtnChangeColor"  Content="🎨 색상 변경"
                    Click="BtnChangeColor_Click" IsEnabled="False" Margin="4,4"/>
            <Button x:Name="BtnRestoreColor" Content="↩ 색상 복원"
                    Click="BtnRestoreColor_Click" IsEnabled="False" Margin="4,4"/>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="4,4"/>
            <Button x:Name="BtnCreateSolid"  Content="💎 간섭 솔리드 생성"
                    Click="BtnCreateSolid_Click" IsEnabled="False" Margin="4,4"/>
            <Button x:Name="BtnExportCsv"    Content="📄 CSV 내보내기"
                    Click="BtnExportCsv_Click"   IsEnabled="False" Margin="4,4"/>
            <Button x:Name="BtnReport"       Content="📋 도면에 보고서"
                    Click="BtnReport_Click"      IsEnabled="False" Margin="4,4"/>
        </StackPanel>

        <!-- ── 통계 바 ──────────────────────────────────── -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatG1"     Margin="0,0,20,0" Foreground="#888"/>
                <TextBlock x:Name="StatG2"     Margin="0,0,20,0" Foreground="#888"/>
                <TextBlock x:Name="StatPairs"  Margin="0,0,20,0" Foreground="#888"/>
                <TextBlock x:Name="StatBool"   Margin="0,0,20,0" Foreground="#888"/>
                <TextBlock x:Name="StatFound"  Margin="0,0,20,0" Foreground="#F44336" FontWeight="Bold"/>
                <TextBlock x:Name="StatTime"   Margin="0,0,20,0" Foreground="#888"/>
            </StackPanel>
        </Border>

        <!-- ── 메인: 좌(트리) + 우(리스트) ──────────────── -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌: 레이어 요약 트리 -->
            <GroupBox Grid.Column="0" Header="레이어별 요약">
                <TreeView x:Name="SummaryTree"
                          Background="#2D2D2D" BorderBrush="#444"
                          Foreground="#DCDCDC"
                          SelectedItemChanged="SummaryTree_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Label}"  Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding CountLabel}" Foreground="#F44336" FontWeight="Bold"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </GroupBox>

            <!-- 분리선 -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch" Background="#444"/>

            <!-- 우: 간섭 목록 -->
            <GroupBox Grid.Column="2" Header="간섭 목록 (그룹1 기준)">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 필터 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="필터: " VerticalAlignment="Center" Foreground="#888"/>
                        <TextBox x:Name="FilterBox" Width="200" Margin="4,0"
                                 Background="#3C3C3C" Foreground="#DCDCDC" BorderBrush="#555"
                                 TextChanged="FilterBox_TextChanged"/>
                        <TextBlock x:Name="ListCountLabel" VerticalAlignment="Center"
                                   Margin="10,0" Foreground="#888"/>
                    </StackPanel>

                    <!-- 결과 리스트 -->
                    <ListView x:Name="ResultListView" Grid.Row="1"
                              Background="#2D2D2D" BorderBrush="#444"
                              Foreground="#DCDCDC"
                              SelectionMode="Extended"
                              SelectionChanged="ResultListView_SelectionChanged"
                              MouseDoubleClick="ResultListView_DoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="그룹1 객체"    Width="190"
                                    DisplayMemberBinding="{Binding Group1Entity.DisplayName}"/>
                                <GridViewColumn Header="G1 레이어"     Width="90"
                                    DisplayMemberBinding="{Binding Group1Entity.LayerName}"/>
                                <GridViewColumn Header="그룹2 객체"    Width="190"
                                    DisplayMemberBinding="{Binding Group2Entity.DisplayName}"/>
                                <GridViewColumn Header="G2 레이어"     Width="90"
                                    DisplayMemberBinding="{Binding Group2Entity.LayerName}"/>
                                <GridViewColumn Header="간섭 체적"     Width="90"
                                    DisplayMemberBinding="{Binding VolumeText}"/>
                                <GridViewColumn Header="간섭 중심"     Width="160"
                                    DisplayMemberBinding="{Binding CenterText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ── 진행 상태 ─────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="8,0,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="ProgressBar" Grid.Row="0" Height="6"
                         Minimum="0" Maximum="100" Value="0"
                         Background="#3C3C3C" Foreground="#0078D4"/>
            <TextBlock x:Name="StatusText" Grid.Row="1"
                       Margin="0,3" Foreground="#888" FontSize="11"/>
        </Grid>

        <!-- ── 하단 버튼 ─────────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="8,0,8,8">
            <TextBlock x:Name="ToleranceLabel" VerticalAlignment="Center"
                       Foreground="#888" Margin="0,0,6,0">
                최소 간섭 체적:
            </TextBlock>
            <TextBox x:Name="ToleranceBox" Width="70" Text="0.001"
                     Background="#3C3C3C" Foreground="#DCDCDC" BorderBrush="#555"
                     Padding="4,2" VerticalAlignment="Center"/>
            <Button Content="재검사" Click="BtnRecheck_Click"
                    Background="#0078D4" Foreground="White" BorderBrush="#005A9E"
                    Margin="8,0"/>
            <Button x:Name="BtnCancel" Content="취소"
                    Click="BtnCancel_Click" Width="70"/>
            <Button Content="닫기"  Click="BtnClose_Click"  Width="70"/>
        </StackPanel>
    </Grid>
</Window>
