<Window x:Class="InterferenceCheck.Dialogs.LayerSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#252526" Foreground="#DCDCDC"
        FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Foreground"   Value="#DCDCDC"/>
            <Setter Property="BorderBrush"  Value="#555"/>
            <Setter Property="Padding"      Value="12,4"/>
            <Setter Property="Margin"       Value="4,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#3C3C3C"/>
            <Setter Property="Foreground"  Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding"     Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Margin"     Value="2,1"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" x:Name="TitleText"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="#4FC3F7" Margin="0,0,0,10"/>

        <!-- 검색 -->
        <TextBox Grid.Row="1" x:Name="SearchBox"
                 Margin="0,0,0,6"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- 레이어 목록 -->
        <ListBox Grid.Row="2" x:Name="LayerListBox"
                 Background="#2D2D2D" BorderBrush="#444"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              Content="{Binding Name}"
                              Checked="Check_Changed" Unchecked="Check_Changed"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 전체 선택/해제 + 카운트 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,4">
            <Button Content="전체 선택" Click="SelectAll_Click"/>
            <Button Content="전체 해제" Click="SelectNone_Click"/>
            <TextBlock x:Name="CountLabel" VerticalAlignment="Center"
                       Margin="10,0" Foreground="#888"/>
        </StackPanel>

        <!-- 확인/취소 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="확인" Width="80" Click="OK_Click"
                    Background="#0078D4" Foreground="White" BorderBrush="#005A9E"/>
            <Button Content="취소" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
